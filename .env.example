# =============================================================================
# BYO-SLM environment configuration (Twelve-Factor: config via environment).
# Copy to `.env` for local development. NEVER commit a real `.env`.
# All variables are prefixed with SLM_ and consumed by slm.config.Settings.
# =============================================================================

# ---- Runtime ---------------------------------------------------------------
SLM_ENV=development                 # development | staging | production
SLM_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
SLM_LOG_JSON=false                  # true => structured JSON logs (set true in prod)

# ---- Model / inference -----------------------------------------------------
SLM_MODEL_DIR=./checkpoints/tiny    # directory containing model.pt + tokenizer.json
SLM_DEVICE=auto                     # auto | cpu | cuda | mps
SLM_MAX_NEW_TOKENS=256              # hard ceiling on generated tokens per request
SLM_MAX_PROMPT_TOKENS=1024          # reject prompts longer than this (after tokenizing)

# ---- API server ------------------------------------------------------------
SLM_API_HOST=0.0.0.0
SLM_API_PORT=8000
SLM_API_WORKERS=1                   # uvicorn workers; scale horizontally instead for GPU
SLM_CORS_ORIGINS=*                  # comma-separated allowlist, e.g. https://app.example.com

# ---- Security --------------------------------------------------------------
# Comma-separated list of accepted API keys. Empty => auth DISABLED (dev only!).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SLM_API_KEYS=
SLM_RATE_LIMIT_PER_MINUTE=60        # per-API-key request budget per minute
SLM_RATE_LIMIT_BURST=10            # token-bucket burst capacity
